    <!-- VerdictNarrative: explanation exposure -->
    <string name="narrative_explanation_exposure_remote">The local Xray API exposed a remote endpoint address.</string>
    <string name="narrative_explanation_exposure_public_ip">Only the public egress IP was visible, not the final server address.</string>
    <string name="narrative_explanation_exposure_local_proxy">Only a local proxy/API on the device was visible, without the remote endpoint address.</string>
    <string name="narrative_explanation_exposure_technical">Only technical network and routing signals were available, without a server address.</string>
    <string name="narrative_explanation_exposure_insufficient">Neither a server address nor a public IP could be obtained.</string>

    <!-- VerdictNarrative: meaning rows -->
    <string name="narrative_meaning_detected">A red verdict means the automated check collected enough signs of a bypass.</string>
    <string name="narrative_meaning_needs_review">A yellow verdict means signals exist, but they need manual verification.</string>
    <string name="narrative_meaning_not_detected">A green verdict means no decisive bypass signals were found.</string>
    <string name="narrative_meaning_exposure_remote">An actual remote endpoint address was obtained, not just a public IP.</string>
    <string name="narrative_meaning_exposure_public_ip">A public IP and a final server address are not the same: internet services only see the egress IP, which may be just an exit point.</string>
    <string name="narrative_meaning_exposure_local_proxy">A local proxy/API indicates an on-device bypass mechanism, but does not reveal the remote server by itself.</string>
    <string name="narrative_meaning_exposure_technical">Technical signals confirm network behavior, but do not reveal the remote endpoint address.</string>
    <string name="narrative_meaning_exposure_insufficient">With the current data, it is not possible to tell whether the app learned the bypass server address.</string>

